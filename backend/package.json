{
  "name": "lms-backend",
  "version": "1.0.0",
  "description": "LMS Backend - Node.js + Express + TypeScript + Knex + MySQL",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r dotenv/config src/server.ts",
    "build": "tsc",
    "start": "node -r dotenv/config dist/server.js",
    "migrate": "ts-node --transpile-only -r dotenv/config node_modules/.bin/knex migrate:latest --knexfile knexfile.ts",
    "migrate:prod": "npx knex migrate:latest --knexfile knexfile.ts --env production",
    "migrate:rollback": "ts-node --transpile-only -r dotenv/config node_modules/.bin/knex migrate:rollback --knexfile knexfile.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@huggingface/inference": "^4.13.15",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "mysql2": "^3.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
